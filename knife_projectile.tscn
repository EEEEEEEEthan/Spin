[sub_resource type="Shader" id="Shader_m8wqu"]
code = "shader_type spatial;

// 与 outline_unlit 相同：先按距离旋转，再沿法线外扩，cull_front 形成轮廓壳。
render_mode unshaded, cull_front, depth_draw_opaque;

uniform vec3 rotation_axis = vec3(0.0, 1.0, 0.0);
uniform vec3 axis_center_model = vec3(0.0, 0.0, 0.0);
uniform float influence_radius : hint_range(0.001, 100.0, 0.01) = 2.0;
uniform float max_angle_degrees : hint_range(-360.0, 360.0, 0.1) = 45.0;
uniform float distance_power : hint_range(0.05, 8.0, 0.01) = 2.0;

uniform vec3 outline_color : source_color = vec3(0.08, 0.09, 0.11);
uniform float outline_width : hint_range(0.0, 0.2, 0.0001) = 0.012;

void vertex() {
	vec3 axis_unit = normalize(rotation_axis);
	vec3 offset = VERTEX - axis_center_model;
	float distance_from_center = length(offset);
	float normalized_distance = clamp(distance_from_center / influence_radius, 0.0, 1.0);
	float angle_weight = pow(normalized_distance, distance_power);
	float angle_radians = radians(max_angle_degrees) * angle_weight;
	float cosine = cos(angle_radians);
	float sine = sin(angle_radians);
	vec3 rotated_offset = offset * cosine + cross(axis_unit, offset) * sine
			+ axis_unit * dot(axis_unit, offset) * (1.0 - cosine);
	vec3 rotated_vertex = rotated_offset + axis_center_model;
	vec3 n = NORMAL;
	vec3 rotated_normal = normalize(n * cosine + cross(axis_unit, n) * sine
			+ axis_unit * dot(axis_unit, n) * (1.0 - cosine));
	vec3 t = TANGENT.xyz;
	TANGENT.xyz = normalize(t * cosine + cross(axis_unit, t) * sine
			+ axis_unit * dot(axis_unit, t) * (1.0 - cosine));
	VERTEX = rotated_vertex + normalize(rotated_normal) * outline_width;
	NORMAL = rotated_normal;
}

void fragment() {
	ALBEDO = outline_color;
}
"

