[sub_resource type="GDScript" id="GDScript_itxqv"]
script/source = "@tool
extends Node3D

@export var mat_inner: Material
@export var mat_outline: Material

@export var rotation_axis: Vector3 = Vector3(1, 0, 0):
	get:
		return rotation_axis
	set(value):
		rotation_axis = value
		mat_inner.set_shader_parameter('rotation_axis', value)
		mat_outline.set_shader_parameter('rotation_axis', value)

@export var axis_center_model: Vector3 = Vector3.ZERO:
	get:
		return axis_center_model
	set(value):
		axis_center_model = value
		mat_inner.set_shader_parameter('axis_center_model', value)
		mat_outline.set_shader_parameter('axis_center_model', value)

@export_range(0.001, 100.0, 0.01) var influence_radius: float:
	get:
		return influence_radius
	set(value):
		influence_radius = value
		mat_inner.set_shader_parameter('influence_radius', value)
		mat_outline.set_shader_parameter('influence_radius', value)

@export_range(-360.0, 360.0, 0.1) var max_angle_degrees: float = -360.0:
	get:
		return max_angle_degrees
	set(value):
		max_angle_degrees = value
		mat_inner.set_shader_parameter('max_angle_degrees', value)
		mat_outline.set_shader_parameter('max_angle_degrees', value)

@export_range(0.05, 8.0, 0.01) var distance_power: float = 2.89:
	get:
		return distance_power
	set(value):
		distance_power = value
		mat_inner.set_shader_parameter('distance_power', value)
		mat_outline.set_shader_parameter('distance_power', value)

@export var outline_color: Color = Color(0.08, 0.09, 0.11):
	get:
		return outline_color
	set(value):
		outline_color = value
		mat_outline.set_shader_parameter('outline_color', value)

@export_range(0.0, 0.2, 0.0001) var outline_width: float = 0.008:
	get:
		return outline_width
	set(value):
		outline_width = value
		mat_outline.set_shader_parameter('outline_width', value)

func _ready() -> void:
	rotation_axis = rotation_axis
	axis_center_model = axis_center_model
	influence_radius = influence_radius
	max_angle_degrees = max_angle_degrees
	distance_power = distance_power
	outline_color = outline_color
	outline_width = outline_width
"

[sub_resource type="Shader" id="Shader_m8wqu"]
code = "shader_type spatial;

// 与 outline_unlit 相同：先按距离旋转，再沿法线外扩，cull_front 形成轮廓壳。
render_mode unshaded, cull_front, depth_draw_opaque;

uniform vec3 rotation_axis = vec3(0.0, 1.0, 0.0);
uniform vec3 axis_center_model = vec3(0.0, 0.0, 0.0);
uniform float influence_radius : hint_range(0.001, 100.0, 0.01) = 2.0;
uniform float max_angle_degrees : hint_range(-360.0, 360.0, 0.1) = 45.0;
uniform float distance_power : hint_range(0.05, 8.0, 0.01) = 2.0;

uniform vec3 outline_color : source_color = vec3(0.08, 0.09, 0.11);
uniform float outline_width : hint_range(0.0, 0.2, 0.0001) = 0.012;

void vertex() {
	vec3 axis_unit = normalize(rotation_axis);
	vec3 offset = VERTEX - axis_center_model;
	float distance_from_center = length(offset);
	float normalized_distance = clamp(distance_from_center / influence_radius, 0.0, 1.0);
	float angle_weight = pow(normalized_distance, distance_power);
	float angle_radians = radians(max_angle_degrees) * angle_weight;
	float cosine = cos(angle_radians);
	float sine = sin(angle_radians);
	vec3 rotated_offset = offset * cosine + cross(axis_unit, offset) * sine
			+ axis_unit * dot(axis_unit, offset) * (1.0 - cosine);
	vec3 rotated_vertex = rotated_offset + axis_center_model;
	vec3 n = NORMAL;
	vec3 rotated_normal = normalize(n * cosine + cross(axis_unit, n) * sine
			+ axis_unit * dot(axis_unit, n) * (1.0 - cosine));
	vec3 t = TANGENT.xyz;
	TANGENT.xyz = normalize(t * cosine + cross(axis_unit, t) * sine
			+ axis_unit * dot(axis_unit, t) * (1.0 - cosine));
	VERTEX = rotated_vertex + normalize(rotated_normal) * outline_width;
	NORMAL = rotated_normal;
}

void fragment() {
	ALBEDO = outline_color;
}
"

