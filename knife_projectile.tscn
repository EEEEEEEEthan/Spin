[sub_resource type="GDScript" id="GDScript_itxqv"]
script/source = "extends RigidBody3D

## 组 balloon 且含 explode()：仅戳破（queue_free），飞刀不冻结、不 reparent。
## 命中体的 collision_layer 与此掩码有交集时才扎住并 reparent。为 0 时保持旧行为：任意碰撞体均可扎住。
@export_flags_3d_physics var stick_collision_layer_mask: int = 0

## 接触点处两物体世界速度的相对速度模长 ≥ 此值才扎住（含角速度带来的线速度）。≤0 表示不限制。
@export var min_stick_relative_speed: float = 0.0

## 刀尖在本地空间的朝向（单位向量，与场景里「刀刃方向」一致）；相对速度需与此方向大致同向才扎住。
@export var stick_tip_direction_local: Vector3 = Vector3(0, -1, 0)

## 相对速度（归一化）与刀尖朝向点积下限；1 为完全同向，0 为垂直，负为背向。
@export_range(-1.0, 1.0, 0.01) var min_stick_velocity_alignment: float = 0.5

## 接触法线与刚体本地 (0,1,0) 在世界空间中方向的锐角上限（度）；大于则不扎。90 表示不启用此限制。
@export_range(0.0, 90.0, 0.1) var max_stick_normal_body_y_angle_deg: float = 90.0

## 首次碰撞后，对组 balloon 的延迟：f1(d) = 系数 / (d + ε)，与 d 负相关（d 越大延迟越短）。
@export var shockwave_delay_meter_scale: float = 0.15
@export var shockwave_distance_epsilon: float = 0.05

## 冲击冲量系数：|f2| = 系数 / (d + ε)，方向与首次撞击速度 x 相同，|f2| 与 d 负相关。
@export var shockwave_impulse_meter_scale: float = 0.0001

var _stuck: bool = false
var _first_collision_recorded: bool = false


func _try_pop_balloon(hit_body: Node3D, contact_index: int, state: PhysicsDirectBodyState3D) -> bool:
	if not hit_body.is_in_group(\"balloon\"):
		return false
	if not hit_body.has_method(\"explode\"):
		return false
	if min_stick_relative_speed > 0.0:
		var self_at_contact := state.get_contact_local_velocity_at_position(contact_index)
		var other_at_contact := state.get_contact_collider_velocity_at_position(contact_index)
		var relative_velocity := self_at_contact - other_at_contact
		if relative_velocity.length() < min_stick_relative_speed:
			return false
	hit_body.explode()
	return true


func _hit_allows_stick(hit_body: Node) -> bool:
	if stick_collision_layer_mask == 0:
		return true
	var collision_object := hit_body as CollisionObject3D
	if collision_object == null:
		return false
	return (collision_object.collision_layer & stick_collision_layer_mask) != 0


func _shockwave_delay_from_distance(distance: float) -> float:
	return shockwave_delay_meter_scale / (distance + shockwave_distance_epsilon)


func _shockwave_impulse_from_distance_and_velocity(distance: float, velocity_x: Vector3) -> Vector3:
	var speed: float = velocity_x.length()
	if speed < 1e-6:
		return Vector3.ZERO
	var magnitude: float = shockwave_impulse_meter_scale / (distance + shockwave_distance_epsilon)
	return velocity_x.normalized() * magnitude


func _schedule_balloon_shockwave_responses(velocity_x: Vector3) -> void:
	var tree := get_tree()
	if tree == null:
		return
	var origin: Vector3 = global_position
	for node in tree.get_nodes_in_group(\"balloon\"):
		var balloon := node as RigidBody3D
		if balloon == null:
			continue
		var distance: float = origin.distance_to(balloon.global_position)
		var delay_seconds: float = _shockwave_delay_from_distance(distance)
		var impulse: Vector3 = _shockwave_impulse_from_distance_and_velocity(distance, velocity_x)
		if impulse.length_squared() < 1e-12:
			continue
		tree.create_timer(delay_seconds).timeout.connect(
			_apply_shockwave_impulse_to_balloon_if_valid.bind(balloon, impulse), CONNECT_ONE_SHOT)


func _apply_shockwave_impulse_to_balloon_if_valid(balloon: RigidBody3D, impulse: Vector3) -> void:
	if not is_instance_valid(balloon) or not balloon.is_inside_tree():
		return
	if balloon.has_method(\"apply_knife_shockwave_impulse\"):
		balloon.call(\"apply_knife_shockwave_impulse\", impulse)


func _on_first_collision(state: PhysicsDirectBodyState3D) -> void:
	var velocity_x: Vector3 = state.linear_velocity
	state.linear_velocity = velocity_x
	_schedule_balloon_shockwave_responses(velocity_x)


func _ready() -> void:
	add_to_group(\"knife_projectile\")
	contact_monitor = true
	max_contacts_reported = 8


func _integrate_forces(state: PhysicsDirectBodyState3D) -> void:
	if _stuck:
		return
	for contact_index in state.get_contact_count():
		var hit_body := state.get_contact_collider_object(contact_index) as Node3D
		if hit_body == null or hit_body == self:
			continue
		if not _first_collision_recorded:
			_first_collision_recorded = true
			_on_first_collision(state)
		if _try_pop_balloon(hit_body, contact_index, state):
			break
		if not _hit_allows_stick(hit_body):
			continue
		var self_at_contact := state.get_contact_local_velocity_at_position(contact_index)
		var other_at_contact := state.get_contact_collider_velocity_at_position(contact_index)
		var relative_velocity := self_at_contact - other_at_contact
		var relative_speed: float = relative_velocity.length()
		if min_stick_relative_speed > 0.0 and relative_speed < min_stick_relative_speed:
			continue
		if relative_speed < 1e-6:
			continue
		var tip_global: Vector3 = global_transform.basis * stick_tip_direction_local.normalized()
		if tip_global.length_squared() < 1e-12:
			tip_global = Vector3(0, -1, 0)
		else:
			tip_global = tip_global.normalized()
		if relative_velocity.normalized().dot(tip_global) < min_stick_velocity_alignment:
			continue
		# get_contact_local_normal 在 Godot 4 中实为世界空间法线，勿乘 global_transform.basis。
		var normal_world: Vector3 = state.get_contact_local_normal(contact_index).normalized()
		if normal_world.length_squared() < 1e-12:
			continue
		if max_stick_normal_body_y_angle_deg < 89.99:
			var body_y_world: Vector3 = (state.transform.basis * Vector3(0, 1, 0)).normalized()
			var abs_dot: float = clampf(absf(normal_world.dot(body_y_world)), 0.0, 1.0)
			var min_cos: float = cos(deg_to_rad(max_stick_normal_body_y_angle_deg))
			if abs_dot < min_cos:
				continue
		_stuck = true
		state.linear_velocity = Vector3.ZERO
		state.angular_velocity = Vector3.ZERO
		freeze = true
		freeze_mode = RigidBody3D.FREEZE_MODE_STATIC
		call_deferred(\"_reparent_to_hit\", hit_body)
		break


func _reparent_to_hit(hit_body: Node3D) -> void:
	if not is_instance_valid(hit_body) or not is_inside_tree():
		return
	reparent(hit_body)
"

