[gd_scene format=3 uid="uid://c8c7skmlgx1bw"]

[ext_resource type="PackedScene" uid="uid://q7cck1xb2vm" path="res://Chapter1.tscn" id="2_xkndl"]
[ext_resource type="AudioStream" uid="uid://cc65t1i8m2q85" path="res://Audios/口哨进行曲.wav" id="3_bgm"]

[sub_resource type="GDScript" id="GDScript_wbfu4"]
script/source = "extends Node

const _OVERLAY_HIDE_SEC := 0.45
const _OVERLAY_SHOW_SEC := 0.35
const _TRANSITION_SHADER_INDEX := 1
const _TYPEWRITER_CHAR_SEC := 0.1
const _FINAL_SCORE_GAP_SEC := 0.5
const _FINAL_SCORE_HOLD_SEC := 3.0
const _BGM_FADE_OUT_SEC := 2.0

var _editor_force_completion_running: bool = false

@onready var _bgm_player: AudioStreamPlayer = $BgmPlayer


func _ready() -> void:
	var bgm_wav := _bgm_player.stream as AudioStreamWAV
	if bgm_wav != null:
		bgm_wav.loop_mode = AudioStreamWAV.LOOP_FORWARD
	_bgm_player.volume_db = 0.0
	Transition.clear_caption()
	await Transition.switch_overlay(_TRANSITION_SHADER_INDEX, true, _OVERLAY_HIDE_SEC)
	Transition.set_overlay_blocks_input(false)
	_bgm_player.play()
	_connect_current_chapter_completion_signals()


func _unhandled_input(event: InputEvent) -> void:
	if not OS.has_feature(\"editor\"):
		return
	if not event is InputEventKey:
		return
	var key_event := event as InputEventKey
	if not key_event.pressed or key_event.echo:
		return
	if key_event.keycode != KEY_R:
		return
	_force_current_chapter_complete_in_editor()
	get_viewport().set_input_as_handled()


func _connect_current_chapter_completion_signals() -> void:
	var chapter_root: Node = get_node_or_null(\"Game2\")
	if chapter_root == null:
		return
	if chapter_root.has_signal(&\"all_balloons_cleared\"):
		chapter_root.all_balloons_cleared.connect(_on_chapter1_all_balloons_cleared)
	if chapter_root.has_signal(&\"all_targets_hit\"):
		chapter_root.all_targets_hit.connect(_on_chapter2_all_targets_hit)
	if chapter_root.has_signal(&\"all_chapter3_cleared\"):
		chapter_root.all_chapter3_cleared.connect(_on_chapter3_all_cleared)
	if chapter_root.has_signal(&\"all_chapter4_cleared\"):
		chapter_root.all_chapter4_cleared.connect(_on_chapter4_all_cleared)


func _force_current_chapter_complete_in_editor() -> void:
	if _editor_force_completion_running:
		return
	var chapter_root: Node = get_node_or_null(\"Game2\")
	if chapter_root == null:
		return
	_editor_force_completion_running = true
	if chapter_root.has_signal(&\"all_balloons_cleared\"):
		chapter_root.all_balloons_cleared.emit()
		return
	if chapter_root.has_signal(&\"all_targets_hit\"):
		chapter_root.all_targets_hit.emit()
		return
	if chapter_root.has_signal(&\"all_chapter3_cleared\"):
		chapter_root.all_chapter3_cleared.emit()
		return
	if chapter_root.has_signal(&\"all_chapter4_cleared\"):
		chapter_root.all_chapter4_cleared.emit()
		return
	_editor_force_completion_running = false


func _on_chapter1_all_balloons_cleared() -> void:
	await _run_chapter1_cleared_sequence()


func _on_chapter2_all_targets_hit() -> void:
	await _run_chapter2_cleared_sequence()


func _on_chapter3_all_cleared() -> void:
	await _run_chapter3_cleared_sequence()


func _on_chapter4_all_cleared() -> void:
	await _run_chapter4_cleared_sequence()


func _fade_out_bgm_and_stop() -> void:
	if not _bgm_player.playing:
		return
	var tween := create_tween()
	tween.tween_property(_bgm_player, \"volume_db\", -80.0, _BGM_FADE_OUT_SEC)
	await tween.finished
	_bgm_player.stop()


func _run_chapter1_cleared_sequence() -> void:
	Transition.set_overlay_blocks_input(true)
	await Transition.switch_overlay(_TRANSITION_SHADER_INDEX, false, _OVERLAY_SHOW_SEC)
	await get_tree().create_timer(1.0).timeout
	await Transition.typewriter_display(\"击中靶子\", _TYPEWRITER_CHAR_SEC)
	var old_chapter: Node = $Game2
	old_chapter.name = \"_Chapter1_done\"
	var chapter2_root: Node = preload(\"res://Chapter2.tscn\").instantiate()
	chapter2_root.name = \"Game2\"
	add_child(chapter2_root)
	_connect_current_chapter_completion_signals()
	old_chapter.queue_free()
	await get_tree().create_timer(3.0).timeout
	await Transition.switch_overlay(_TRANSITION_SHADER_INDEX, true, _OVERLAY_HIDE_SEC)
	Transition.set_overlay_blocks_input(false)
	_editor_force_completion_running = false


func _run_chapter2_cleared_sequence() -> void:
	Transition.set_overlay_blocks_input(true)
	await Transition.switch_overlay(_TRANSITION_SHADER_INDEX, false, _OVERLAY_SHOW_SEC)
	await get_tree().create_timer(2.0).timeout
	await Transition.typewriter_display(\"别担心\", _TYPEWRITER_CHAR_SEC)
	var old_chapter: Node = $Game2
	old_chapter.name = \"_Chapter2_done\"
	var chapter3_root: Node = preload(\"res://Chapter3.tscn\").instantiate()
	chapter3_root.name = \"Game2\"
	add_child(chapter3_root)
	_connect_current_chapter_completion_signals()
	old_chapter.queue_free()
	await get_tree().create_timer(3.0).timeout
	await Transition.switch_overlay(_TRANSITION_SHADER_INDEX, true, _OVERLAY_HIDE_SEC)
	Transition.set_overlay_blocks_input(false)
	_editor_force_completion_running = false


func _run_chapter3_cleared_sequence() -> void:
	Transition.set_overlay_blocks_input(true)
	await Transition.switch_overlay(_TRANSITION_SHADER_INDEX, false, _OVERLAY_SHOW_SEC)
	await get_tree().create_timer(2.0).timeout
	await Transition.typewriter_display(\"转！\", _TYPEWRITER_CHAR_SEC)
	var old_chapter: Node = $Game2
	old_chapter.name = \"_Chapter3_done\"
	var chapter4_root: Node = preload(\"res://Chapter4.tscn\").instantiate()
	chapter4_root.name = \"Game2\"
	add_child(chapter4_root)
	_connect_current_chapter_completion_signals()
	old_chapter.queue_free()
	await get_tree().create_timer(3.0).timeout
	await Transition.switch_overlay(_TRANSITION_SHADER_INDEX, true, _OVERLAY_HIDE_SEC)
	Transition.set_overlay_blocks_input(false)
	_editor_force_completion_running = false


func _run_chapter4_cleared_sequence() -> void:
	Transition.set_overlay_blocks_input(true)
	await Transition.switch_overlay(_TRANSITION_SHADER_INDEX, false, _OVERLAY_SHOW_SEC)
	await get_tree().create_timer(2.0).timeout
	await Transition.typewriter_display(\"游戏结束喽！\", _TYPEWRITER_CHAR_SEC)
	var final_score: int = PlayerSession.current_human_hit_count
	Transition.clear_caption()
	await get_tree().create_timer(_FINAL_SCORE_GAP_SEC).timeout
	await Transition.typewriter_display(\"你中了%d刀！\" % final_score, _TYPEWRITER_CHAR_SEC)
	await get_tree().create_timer(_FINAL_SCORE_HOLD_SEC).timeout
	await _fade_out_bgm_and_stop()
	PlayerSession.submit_current_score_and_prepare_focus()
	Transition.begin_delayed_overlay_reveal(_TRANSITION_SHADER_INDEX, 0.0, _OVERLAY_HIDE_SEC)
	_editor_force_completion_running = false
	get_tree().change_scene_to_file(\"res://MainMenu.tscn\")
"

[node name="Game3" type="Node" unique_id=538117735]
script = SubResource("GDScript_wbfu4")

