[sub_resource type="GDScript" id="GDScript_v22yx"]
script/source = "extends Node3D
## Trigger（Human）飞刀击中报告的部位名，与 PhysicalBone3D.bone_name 一致。
const knife_hit_right_foot_part: StringName = &\"右脚\"
const knife_hit_left_foot_part: StringName = &\"左脚\"
const knife_hit_right_leg_part: StringName = &\"右腿\"
const knife_hit_left_leg_part: StringName = &\"左腿\"
const knife_hit_hip_part: StringName = &\"髋\"
const knife_hit_left_hip_part: StringName = &\"左髋\"
const knife_hit_right_hip_part: StringName = &\"右髋\"
const knife_hit_chest_part: StringName = &\"胸\"
const knife_hit_head_part: StringName = &\"头\"
const knife_hit_right_hand_part: StringName = &\"右手\"
const knife_hit_left_hand_part: StringName = &\"左手\"
const knife_hit_right_arm_part: StringName = &\"右臂\"
const knife_hit_left_arm_part: StringName = &\"左臂\"
const knife_hit_right_shoulder_part: StringName = &\"右肩\"
const knife_hit_left_shoulder_part: StringName = &\"左肩\"
## 主 Skeleton3D 上 AnimationPlayer 的动画名（自 Human.blend 导入）。
const right_foot_dodge_animation: StringName = &\"右脚闪避\"
const right_leg_dodge_animation: StringName = &\"右腿闪避\"
const body_dodge_animation: StringName = &\"身体闪避\"
const right_hand_dodge_animation: StringName = &\"右手闪避\"
const head_dodge_animation: StringName = &\"头部闪避\"
## 最后一次播放闪避后，无新的播放则此时长后回到 RESET；期间再次播放会重新计时。
const dodge_reset_delay_seconds: float = 0.5
## 切回 RESET 时的混合时长（秒）。
const dodge_reset_blend_seconds: float = 0.1

var _dodge_reset_generation: int = 0
## 已触发过闪避动画的飞刀 instance_id，同一把飞刀多骨骼重叠只响应一次。
var _dodge_responded_knife_instance_ids: Dictionary = {}
## 记录根节点初始 scale.x，左侧部位镜像闪避后仍能还原。
var _dodge_scale_x_default: float = 1.0

func _ready() -> void:
	_dodge_scale_x_default = scale.x
	$Trigger.knife_hit_body_part.connect(_on_trigger_knife_hit_body_part)


func _on_trigger_knife_hit_body_part(body_part: String, _stuck: bool, knife: Node) -> void:
	var body_name := StringName(body_part)
	var dodge_animation: StringName
	var mirror_horizontal: bool
	match body_name:
		knife_hit_right_foot_part:
			dodge_animation = right_foot_dodge_animation
			mirror_horizontal = false
		knife_hit_left_foot_part:
			dodge_animation = right_foot_dodge_animation
			mirror_horizontal = true
		knife_hit_right_leg_part:
			dodge_animation = right_leg_dodge_animation
			mirror_horizontal = false
		knife_hit_left_leg_part:
			dodge_animation = right_leg_dodge_animation
			mirror_horizontal = true
		knife_hit_right_hand_part, knife_hit_right_arm_part, knife_hit_right_shoulder_part:
			dodge_animation = right_hand_dodge_animation
			mirror_horizontal = false
		knife_hit_left_hand_part, knife_hit_left_arm_part, knife_hit_left_shoulder_part:
			dodge_animation = right_hand_dodge_animation
			mirror_horizontal = true
		knife_hit_hip_part, knife_hit_chest_part, knife_hit_right_hip_part:
			dodge_animation = body_dodge_animation
			mirror_horizontal = false
		knife_hit_left_hip_part:
			dodge_animation = body_dodge_animation
			mirror_horizontal = true
		knife_hit_head_part:
			dodge_animation = head_dodge_animation
			mirror_horizontal = false
		_:
			return
	var animation_player: AnimationPlayer = $AnimationPlayer
	if not animation_player.has_animation(dodge_animation):
		return
	if knife != null:
		var knife_instance_id: int = knife.get_instance_id()
		if _dodge_responded_knife_instance_ids.has(knife_instance_id):
			return
		_dodge_responded_knife_instance_ids[knife_instance_id] = true
	_apply_dodge_horizontal_mirror(mirror_horizontal)
	animation_player.play(dodge_animation)
	_schedule_reset_after_dodge(animation_player)


func _apply_dodge_horizontal_mirror(mirror_horizontal: bool) -> void:
	var magnitude: float = absf(_dodge_scale_x_default)
	if magnitude < 0.0001:
		magnitude = 1.0
	var sign_default: float = signf(_dodge_scale_x_default)
	if sign_default == 0.0:
		sign_default = 1.0
	var mirror_sign: float = -1.0 if mirror_horizontal else 1.0
	scale.x = magnitude * sign_default * mirror_sign


func _schedule_reset_after_dodge(animation_player: AnimationPlayer) -> void:
	_dodge_reset_generation += 1
	var generation: int = _dodge_reset_generation
	await get_tree().create_timer(dodge_reset_delay_seconds).timeout
	if generation != _dodge_reset_generation:
		return
	if animation_player.has_animation(&\"RESET\"):
		animation_player.play(&\"RESET\", dodge_reset_blend_seconds)
		await get_tree().create_timer(dodge_reset_blend_seconds).timeout
		if generation != _dodge_reset_generation:
			return
		scale.x = _dodge_scale_x_default
		_dodge_responded_knife_instance_ids.clear()
	else:
		_dodge_responded_knife_instance_ids.clear()
"

