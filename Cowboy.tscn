[sub_resource type="GDScript" id="GDScript_v22yx"]
script/source = "extends Node3D
## Trigger（Human）飞刀击中报告的部位名，与 PhysicalBone3D.bone_name 一致。
const knife_hit_right_foot_part: StringName = &\"右脚\"
## 主 Skeleton3D 上 AnimationPlayer 的动画名（自 Human.blend 导入）。
const right_foot_dodge_animation: StringName = &\"右脚闪避\"

func _ready() -> void:
	$Trigger.knife_hit_body_part.connect(_on_trigger_knife_hit_body_part)


func _on_trigger_knife_hit_body_part(body_part: String, _stuck: bool) -> void:
	if StringName(body_part) != knife_hit_right_foot_part:
		return
	if not $AnimationPlayer.has_animation(right_foot_dodge_animation):
		return
	$AnimationPlayer.play(right_foot_dodge_animation)
"

