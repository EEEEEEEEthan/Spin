[gd_scene load_steps=4 format=3 uid="uid://choxg0x7j0m2l"]

[ext_resource type="Script" path="res://transition_rect.gd" id="1_rect"]

[sub_resource type="Shader" id="Shader_ch01m"]
code = "shader_type canvas_item;

uniform float slat_count : hint_range(1.0, 128.0) = 16.0;
// COLOR.a：1 全黑、0 全透。幂 <1 更快变透；>1 更慢；顶/底插值。
uniform float power_top : hint_range(0.25, 8.0) = 0.5;
uniform float power_bottom : hint_range(0.25, 8.0) = 2.5;

void fragment() {
	float a = clamp(1.0 - COLOR.a, 0.0, 1.0);
	float power = mix(power_top, power_bottom, UV.y);
	float open = pow(a, power);
	float local_y = fract(UV.y * slat_count);
	float closed = step(open, local_y);
	COLOR = vec4(0.0, 0.0, 0.0, closed);
}
"

