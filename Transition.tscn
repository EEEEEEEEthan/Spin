[gd_scene format=3 uid="uid://choxg0x7j0m2l"]

[sub_resource type="Shader" id="Shader_ch01m"]
code = "shader_type canvas_item;

uniform float slat_count : hint_range(1.0, 128.0) = 16.0;

void fragment() {
	float open = COLOR.a;
	float local_y = fract(UV.y * slat_count);
	// open=0 全闭合(黑)；open=1 全开(透明)；自每格顶部向下展开，硬边
	float closed = step(open, local_y);
	COLOR = vec4(0.0, 0.0, 0.0, closed);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_ws5yv"]
shader = SubResource("Shader_ch01m")
shader_parameter/slat_count = 16.0

[sub_resource type="GDScript" id="GDScript_ch01m"]
script/source = "@tool
extends ColorRect

@export var materials: Array[Material] = []
@export var index: int:
	get:
		return index
	set(value):
		index = value
		if not materials.is_empty():
			material = materials[posmod(index, materials.size())]

var _switch_tween: Tween

func switch(idx: int, on: bool, duration: float):
	index = idx
	if _switch_tween != null and _switch_tween.is_valid():
		_switch_tween.kill()
	var target_alpha := 1.0 if on else 0.0
	_switch_tween = create_tween()
	_switch_tween.tween_property(self, \"self_modulate:a\", target_alpha, duration)
"

