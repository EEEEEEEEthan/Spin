[gd_scene format=3 uid="uid://choxg0x7j0m2l"]

[sub_resource type="GDScript" id="GDScript_ch01m"]
script/source = "extends ColorRect

@export var materials: Array[Material] = []

var _switch_tween: Tween

func switch(index: int, on: bool, duration: float):
	# index会把材质设置为材质列表里的第index个(长度取模)
	if not materials.is_empty():
		material = materials[posmod(index, materials.size())]
	if _switch_tween != null and _switch_tween.is_valid():
		_switch_tween.kill()
	var target_alpha := 1.0 if on else 0.0
	_switch_tween = create_tween()
	_switch_tween.tween_property(self, \"self_modulate:a\", target_alpha, duration)
"

